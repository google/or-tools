load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//ortools/copts:configure_copts.bzl", "ORTOOLS_DEFAULT_COPTS", "ORTOOLS_DEFAULT_LINKOPTS", "ORTOOLS_TEST_COPTS")

package(default_visibility = [
    "//experimental/users/rander/santorini:__subpackages__",
    "//ortools/javatests/com/google/ortools/mathopt:__subpackages__",
    "//visibility:public",
])

cc_library(
    name = "param_name",
    testonly = True,
    hdrs = ["param_name.h"],
    copts = ORTOOLS_DEFAULT_COPTS,
    linkopts = ORTOOLS_DEFAULT_LINKOPTS,
    deps = [
        "//ortools/base:gmock",
    ],
)

cc_library(
    name = "stream",
    hdrs = ["stream.h"],
    copts = ORTOOLS_DEFAULT_COPTS,
    linkopts = ORTOOLS_DEFAULT_LINKOPTS,
)

cc_test(
    name = "param_name_test",
    srcs = ["param_name_test.cc"],
    copts = ORTOOLS_TEST_COPTS,
    linkopts = ORTOOLS_DEFAULT_LINKOPTS,
    deps = [
        ":param_name",
        "//ortools/base:gmock_main",
    ],
)

cc_test(
    name = "stream_test",
    srcs = ["stream_test.cc"],
    copts = ORTOOLS_TEST_COPTS,
    linkopts = ORTOOLS_DEFAULT_LINKOPTS,
    deps = [
        ":stream",
        "//ortools/base:gmock_main",
    ],
)

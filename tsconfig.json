{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "ortools-cpsat-wasm": ["javascript/lib/index.ts"]
    }
  },
  "include": [
    "javascript/lib/**/*.ts",
    "javascript/lib/**/*.d.ts",
    "javascript/site/**/*.ts"
  ]
}
